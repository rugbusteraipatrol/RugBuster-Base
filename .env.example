# Base mainnet
RUGBUSTER_NETWORK=base
BASE_RPC_URL=https://mainnet.base.org
BASE_RPC=https://mainnet.base.org
BASESCAN_API_KEY=

# Deployment / verification
PRIVATE_KEY=
REGISTRY_ADDRESS=0x5F30276B3A5079E088Ec3072884286de5a868355
SCANNER_ADDRESS=0x5F30276B3A5079E088Ec3072884286de5a868355

# Shared Postgres DB
DATABASE_URL=
DB_TABLE=base_scans

# Collector controls
MIN_SCAN_DELAY_MINUTES=2
MAX_SCAN_DELAY_MINUTES=3
MAX_TOKENS_PER_DAY=120
MAX_ETH_TOTAL=0.05
MAX_EUR_TOTAL=20
TARGET_ETH_PER_SCAN=0.00002
ETH_EUR_PRICE_FALLBACK=3000
RUN_UNTIL_DATE=2026-12-31
REQUIRE_ERC20_METADATA=true
GECKOTERMINAL_ENABLED=true
GECKOTERMINAL_NEW_POOLS_URL=https://api.geckoterminal.com/api/v2/networks/base/new_pools?include=base_token,quote_token
GECKOTERMINAL_TOP_POOLS_ENABLED=true
GECKOTERMINAL_POOL_PAGES=3
GECKOTERMINAL_QUEUE_LOW_WATERMARK=10

# On-chain module logging
ONCHAIN_LOG_ENABLED=false
ACTIVITY_LOGGER_ADDRESS=
BASE_LOG_PRIVATE_KEY=
BOT_PUBLISH_TO_REGISTRY=false

# Recent scan feed / landing page API
RECENT_SCAN_FEED_URL=
RECENT_SCAN_INGEST_TOKEN=

# Local API
RUGBUSTER_API_HOST=0.0.0.0
RUGBUSTER_API_PORT=8787

# Telegram alerts
# Optional dormant integration. Leave disabled for the Base public dashboard.
TELEGRAM_ALERTS=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

